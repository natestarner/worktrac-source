{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/config.json", "/favicon.ico", "/icons.svg", "/og-image.png", "/assets/*", "/email/*", "/apple-touch-icon.png", "/icon.svg", "/icon-192.png", "/icon-512.png", "/manifest.webmanifest"]
  },
  "routes": [
    { "route": "/index.html", "headers": { "Cache-Control": "no-cache" } },
    { "route": "/assets/*", "headers": { "Cache-Control": "public, max-age=31536000, immutable" } }
  ]
}
